rules_version = '2';

// 🛡️ Loyalty-shop Firestore Security Rules
//
// HOW TO DEPLOY:
//   1. Open Firebase Console → Firestore Database → Rules tab
//   2. Replace the entire content with this file
//   3. Click "Publish"
//
// ARCHITECTURE NOTE:
//   The app currently has NO Firebase Authentication — admin login is
//   verified client-side against a SHA-256 hash. So these rules can't
//   distinguish "admin" from "customer" by request.auth.
//
//   What we CAN do:
//   - Public read for menu/settings/images (customer page must render)
//   - Reject deletes from clients (require Firebase Console)
//   - Validate the SHAPE of writes (size, required fields)
//   - Cap total request rate via App Check
//
//   When Firebase Auth is added later, replace `if true` reads with
//   `if request.auth != null` and writes with role checks.

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // 📖 PUBLIC-READABLE configs — customer/menu pages need to read these
    //    without logging in. Writes are still permissive (admin client-side).
    // -----------------------------------------------------------------
    match /settings/{docId} {
      allow read: if true;
      // Limit write payload to 900KB to stay under Firestore 1MB doc limit
      allow write: if request.resource == null
                   || request.resource.size() < 900 * 1024;
      allow delete: if false;
    }

    match /menu_images/{itemId} {
      allow read: if true;
      // Each image doc must have a dataUrl string field, ≤ 900KB
      allow create, update: if request.resource.data.dataUrl is string
                            && request.resource.size() < 900 * 1024;
      allow delete: if true;  // Admin needs to delete via deleteMenuImage
    }

    // -----------------------------------------------------------------
    // 👤 CUSTOMERS — name, points, phone. Customers create their own;
    //    admin updates points. Phone IS the doc id, so reads by id work.
    // -----------------------------------------------------------------
    match /customers/{phone} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 100;
      allow update: if request.resource.data.name is string
                    && request.resource.data.name.size() < 100;
      // Customers should never be hard-deleted (use anonymize tool instead)
      allow delete: if false;
    }

    match /customers/{phone}/{sub=**} {
      // Subcollections (e.g. point_history if added) — same access
      allow read, write: if true;
      allow delete: if false;
    }

    // -----------------------------------------------------------------
    // 🛒 ORDERS — created by customer or walk-in. Kitchen updates status.
    // -----------------------------------------------------------------
    match /orders/{orderId} {
      allow read: if true;
      // Order must have a numeric total and at least one item
      allow create: if request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.total < 100000
                    && request.resource.data.items is list;
      allow update: if true;  // status changes, factory_paid, etc.
      // Hard delete only allowed for factory orders (admin retroactive cleanup)
      allow delete: if true;
    }

    // -----------------------------------------------------------------
    // 🚫 CATCH-ALL — block anything not matched above. Keeps unknown
    //    collections (typos, future docs) safe by default.
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
